        {
            "parameters": {
                "operation": "executeQuery",
                "query": "INSERT INTO public.questions_embeddings (question_id, content, embedding, metadata)\nVALUES (\n  {{ $json.question_id }},\n  $1,\n  $2::vector,\n  $3::jsonb\n);",
                "options": {
                    "queryReplacement": "={{ $json.content }},={{ $json.embedding }},={{ JSON.stringify($json.metadata) }}"
                }
            },
