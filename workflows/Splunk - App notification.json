            "id": "b37f12a4-232d-49e6-bfb4-c80acbb3987d",
            "name": "Appinfo",
            "webhookId": "6834f464-b579-4250-9b15-8b59562edb97"
        },
        {
            "parameters": {
                "jsCode": "// Récupérer le texte du LLM\nconst llmOutput = $input.first().json.text || $input.first().json.output;\n\n// Parser le JSON (en nettoyant les backticks si présents)\nlet cleanedText = llmOutput.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\ntry {\n  const jsonData = JSON.parse(cleanedText);\n  console.log(jsonData)\n  //return { content: jsonData };\n  if (Array.isArray(jsonData)) {\n    return jsonData.map(item => {\n      return {\n        json: {\n          text: item.text\n        }\n      };\n    });\n  }\n} catch (error) {\n  // Si le parsing échoue, retourner l'erreur\n  return { \n    json: { \n      error: \"Failed to parse JSON\", \n      raw_text: llmOutput,\n      error_message: error.message \n    } \n  };\n}"
            },
            "type": "n8n-nodes-base.code",
